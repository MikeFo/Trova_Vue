# Copy to .env.local and adjust for local development.
# Optional: override app base URL (used for siteUrl in local env).
# Defaults to http://localhost:5173 if unset.
# VITE_APP_BASE_URL=http://127.0.0.1:5173

# Optional: route API through Vite proxy to avoid CORS when calling staging from local.
# VITE_API_URL=/api
# VITE_API_TARGET=https://trova-api-staging.herokuapp.com
